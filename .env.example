# Database
DATABASE_URL="postgresql://root:root@localhost:30306/woojulib"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers (선택사항)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

NAVER_CLIENT_ID="your-naver-client-id"
NAVER_CLIENT_SECRET="your-naver-client-secret"

KAKAO_CLIENT_ID="your-kakao-client-id"
KAKAO_CLIENT_SECRET="your-kakao-client-secret"

APPLE_CLIENT_ID="your-apple-client-id"
APPLE_CLIENT_SECRET="your-apple-client-secret"

# External APIs
GOOGLE_BOOKS_API_KEY="your-google-books-api-key"
NAVER_BOOKS_API_KEY="your-naver-books-api-key"
NAVER_BOOKS_API_SECRET="your-naver-books-api-secret"
KAKAO_BOOKS_API_KEY="your-kakao-books-api-key"
# 카카오 도서 검색 (서버 전용 — NEXT_PUBLIC 금지)
KAKAO_REST_API_KEY="your-kakao-rest-api-key"

# Redis (캐싱)
REDIS_URL="redis://localhost:6379"

# AI/ML Services (선택사항)
OPENAI_API_KEY="your-openai-api-key"
GEMINI_API_KEY="your-gemini-api-key"

# Email Service (선택사항)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Application
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
